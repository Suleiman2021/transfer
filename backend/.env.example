# Database
DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/moneytransfersystem

# Security
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
SQL_ECHO=false

# Optional SMTP (if notifications are enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# App identity / bootstrap data
COMPANY_NAME=Cashbox Transfer Network
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_FULL_NAME=System Administrator
BOOTSTRAP_ADMIN_CITY=Qamishli
BOOTSTRAP_ADMIN_COUNTRY=Syria
BOOTSTRAP_TREASURY_NAME=Central Treasury

# Schema safety flags (keep false in production)
FORCE_REBUILD_SCHEMA=false
AUTO_RESET_SCHEMA_ON_MISMATCH=false
